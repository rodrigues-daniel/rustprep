# ╔══════════════════════════════════════════════════════════════╗
# ║  .gitignore — Rust (axum/sqlx) + React (Vite)              ║
# ╚══════════════════════════════════════════════════════════════╝

# ================================================================
# VARIÁVEIS DE AMBIENTE — NUNCA commitar segredos
# ================================================================
.env
.env.*
!.env.example

# ================================================================
# RUST
# ================================================================
target/
Cargo.lock
**/*.rs.bk
*.pdb

# ================================================================
# REACT / NODE
# ================================================================
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local
*.tsbuildinfo

# ================================================================
# EDITORES & IDEs
# ================================================================

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
*#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ================================================================
# SISTEMA OPERACIONAL
# ================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ================================================================
# MISC
# ================================================================
*.bak
*.tmp
*.temp
*.orig
*.log
logs/
.cache/
